# Azure AD
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Power BI
WORKSPACE_ID=your-workspace-id

# 세션 보안 (임의의 긴 문자열로 변경 필수)
SECRET_KEY=change-me-to-at-least-32-random-characters
COOKIE_SECURE=false

# 사용자 업로드 제한
MAX_UPLOADS_PER_DAY=10
MAX_PERSONAL_REPORTS=20

# PBI 삭제 동기화 주기 (초, 0이면 끔 — 시작 시 1회와 관리자 수동 동기화는 항상 동작)
PBI_SYNC_INTERVAL=600

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=powerbi_gateway
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# 커넥션 풀 크기 (프로세스당)
DB_POOL_MIN=2
DB_POOL_MAX=20
