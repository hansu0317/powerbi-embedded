# 클라우드 배포용 .env 설정값
# 이 파일을 .env로 복사 후 실제 값으로 교체

# Azure AD (on-prem과 동일)
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Power BI
WORKSPACE_ID=your-workspace-id

# 세션 보안 — 클라우드에서는 반드시 랜덤 값으로 변경
SECRET_KEY=최소-32자-이상의-랜덤-문자열

# HTTPS 적용 후 true로 변경 (nginx 설정 후)
COOKIE_SECURE=true

# 업로드 제한
MAX_UPLOADS_PER_DAY=10
MAX_PERSONAL_REPORTS=20

# Fabric 동기화 주기 (초)
FABRIC_SYNC_INTERVAL=600

# PostgreSQL — 클라우드 DB 주소로 변경
# Azure: Azure Database for PostgreSQL의 호스트명
# AWS:   RDS 엔드포인트
DB_HOST=your-cloud-db-host.postgres.database.azure.com
DB_PORT=5432
DB_NAME=powerbi_gateway
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# 커넥션 풀 (클라우드 관리형 DB는 연결 수 제한 확인)
DB_POOL_MIN=2
DB_POOL_MAX=10
